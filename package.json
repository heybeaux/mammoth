{
  "name": "mammoth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@8.15.6",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "mammoth": "tsx apps/cli/src/bin.ts",
    "profile:start": "pnpm --filter @mammoth/production-profile exec tsx src/cli.ts start",
    "profile:status": "pnpm --filter @mammoth/production-profile exec tsx src/cli.ts status",
    "profile:stop": "pnpm --filter @mammoth/production-profile exec tsx src/cli.ts stop",
    "profile:kill": "pnpm --filter @mammoth/production-profile exec tsx src/cli.ts kill",
    "test": "pnpm -r --if-present run test",
    "typecheck": "tsc --noEmit && pnpm -r --if-present run typecheck",
    "verify:evidence": "tsx scripts/verify-phase-0.ts",
    "verify:audit": "tsx scripts/verify-phase-0.ts",
    "verify:phase-1": "pnpm --filter @mammoth/retrieval --filter @mammoth/persistence --filter @mammoth/report-compiler test",
    "verify:phase-2": "pnpm --filter @mammoth/workflow --filter @mammoth/work-queue --filter @mammoth/governance test",
    "verify:adapters": "pnpm --filter @mammoth/adapter-contracts test",
    "verify:m2": "pnpm --filter @mammoth/runtime test && pnpm --filter @mammoth/mvp-fixture verify",
    "verify:m3": "pnpm --filter @mammoth/cli test",
    "verify:m4": "pnpm build && tsx scripts/verify-mvp.ts",
    "verify:mvp": "pnpm verify:evidence && pnpm verify:audit && pnpm verify:phase-1 && pnpm verify:phase-2 && pnpm verify:m2 && pnpm verify:m3 && pnpm verify:m4",
    "verify:p2": "tsx scripts/verify-p2.ts",
    "verify:p2:lifecycle": "pnpm --filter @mammoth/production-profile verify:lifecycle",
    "verify:p2:backup": "pnpm --filter @mammoth/production-profile verify:backup",
    "verify:p2:profile": "bash infra/verify-production-profile.sh",
    "verify:p3": "tsx scripts/verify-p3.ts",
    "verify:p4": "tsx scripts/verify-p4.ts",
    "verify:p5": "tsx scripts/verify-p5.ts",
    "verify:p6": "tsx scripts/verify-p6.ts",
    "verify:p7": "tsx scripts/verify-p7.ts",
    "verify:p8": "tsx scripts/verify-p8.ts",
    "verify:p9": "tsx scripts/verify-p9.ts",
    "eval:offline": "tsx scripts/verify-phase-0.ts"
  },
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@types/node": "22.15.34",
    "eslint": "9.30.1",
    "eslint-config-prettier": "10.1.5",
    "globals": "16.3.0",
    "prettier": "3.6.2",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.35.1"
  }
}
