{
  "name": "mammoth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@8.15.6",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "pnpm -r --if-present run test",
    "typecheck": "tsc --noEmit && pnpm -r --if-present run typecheck",
    "verify:evidence": "tsx scripts/verify-phase-0.ts",
    "verify:audit": "tsx scripts/verify-phase-0.ts",
    "verify:phase-1": "pnpm --filter @mammoth/retrieval --filter @mammoth/persistence --filter @mammoth/report-compiler test",
    "eval:offline": "tsx scripts/verify-phase-0.ts"
  },
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@types/node": "22.15.34",
    "eslint": "9.30.1",
    "eslint-config-prettier": "10.1.5",
    "globals": "16.3.0",
    "prettier": "3.6.2",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.35.1"
  }
}
