{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mammoth.local/schemas/mvp-research-fixture-1.0.0.json",
  "title": "Mammoth deterministic MVP research fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "fixtureId",
    "clock",
    "charterPath",
    "sources",
    "claims",
    "expected"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "fixtureId": { "type": "string", "minLength": 1 },
    "clock": { "type": "string", "format": "date-time" },
    "charterPath": { "type": "string", "pattern": "^charter\\.json$" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    },
    "claims": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/claim" }
    },
    "expected": { "$ref": "#/$defs/expected" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sourceUri",
        "publisher",
        "mediaType",
        "snapshotPath",
        "retrievedAt",
        "contentDigest",
        "byteLength",
        "parsedTextDigest"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sourceUri": { "type": "string", "format": "uri" },
        "publisher": { "type": "string", "minLength": 1 },
        "mediaType": { "const": "text/plain" },
        "snapshotPath": {
          "type": "string",
          "pattern": "^source-[a-z0-9-]+\\.txt$"
        },
        "retrievedAt": { "type": "string", "format": "date-time" },
        "contentDigest": { "$ref": "#/$defs/digest" },
        "byteLength": { "type": "integer", "minimum": 1 },
        "parsedTextDigest": { "$ref": "#/$defs/digest" }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "canonicalText",
        "subject",
        "predicate",
        "object",
        "expectedVerdict"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "canonicalText": { "type": "string", "minLength": 1 },
        "subject": { "type": "string", "minLength": 1 },
        "predicate": { "type": "string", "minLength": 1 },
        "object": { "type": "string", "minLength": 1 },
        "expectedVerdict": {
          "enum": ["supported", "contradicted", "unresolved"]
        }
      }
    },
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claimId",
        "sourceId",
        "lineStart",
        "lineEnd",
        "startOffset",
        "endOffset",
        "exactText",
        "stance",
        "entailment"
      ],
      "properties": {
        "claimId": { "type": "string", "minLength": 1 },
        "sourceId": { "type": "string", "minLength": 1 },
        "lineStart": { "type": "integer", "minimum": 1 },
        "lineEnd": { "type": "integer", "minimum": 1 },
        "startOffset": { "type": "integer", "minimum": 0 },
        "endOffset": { "type": "integer", "minimum": 1 },
        "exactText": { "type": "string", "minLength": 1 },
        "stance": { "enum": ["supports", "contradicts"] },
        "entailment": { "const": "direct" }
      }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claimId",
        "policyId",
        "policyVersion",
        "verdict",
        "reasonCodes",
        "evidenceIds"
      ],
      "properties": {
        "claimId": { "type": "string", "minLength": 1 },
        "policyId": { "type": "string", "minLength": 1 },
        "policyVersion": { "type": "string", "minLength": 1 },
        "verdict": { "enum": ["supported", "contradicted", "unresolved"] },
        "reasonCodes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "evidenceIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "locators",
        "assessments",
        "renderedClaimIds",
        "excludedClaimIds"
      ],
      "properties": {
        "locators": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/locator" }
        },
        "assessments": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/assessment" }
        },
        "renderedClaimIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "excludedClaimIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
