# Copy to a private shell environment; never commit an actual value.
MAMMOTH_PG_PASSWORD=replace-with-a-random-secret-at-least-12-characters
MAMMOTH_PROFILE_ROOT=/absolute/path/to/mammoth-production-profile
MAMMOTH_PG_HOST=127.0.0.1
MAMMOTH_PG_PORT=55432
MAMMOTH_PG_USER=mammoth
MAMMOTH_PG_DATABASE=mammoth
MAMMOTH_STARTUP_TIMEOUT_MS=30000
MAMMOTH_SHUTDOWN_TIMEOUT_MS=15000
MAMMOTH_TEMPORAL_CLI=temporal
MAMMOTH_TEMPORAL_HOST=127.0.0.1
MAMMOTH_TEMPORAL_PORT=7233
MAMMOTH_TEMPORAL_NAMESPACE=mammoth-local
MAMMOTH_TEMPORAL_TASK_QUEUE=research-control
MAMMOTH_TEMPORAL_RETENTION_DAYS=3
MAMMOTH_TEMPORAL_STARTUP_TIMEOUT_MS=30000
MAMMOTH_TEMPORAL_SHUTDOWN_TIMEOUT_MS=15000
MAMMOTH_TEMPORAL_READINESS_TIMEOUT_MS=5000
