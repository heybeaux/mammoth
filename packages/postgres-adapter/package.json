{
  "name": "@mammoth/postgres-adapter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:ledger": "vitest run test/ledger.test.ts",
    "test:migrations": "vitest run test/lifecycle.test.ts",
    "test:work-effects": "vitest run test/work-outbox.test.ts",
    "verify:p2:d4": "vitest run test/work-outbox.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mammoth/adapter-contracts": "workspace:*",
    "@mammoth/persistence": "workspace:*",
    "@mammoth/work-queue": "workspace:*"
  },
  "devDependencies": {
    "@mammoth/domain": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
