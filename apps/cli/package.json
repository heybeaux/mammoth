{
  "name": "@mammoth/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "mammoth": "./dist/bin.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "pnpm --filter @mammoth/temporal-adapter build && tsc -p tsconfig.build.json && esbuild src/bin.ts --bundle --splitting --platform=node --format=esm --target=node22 --external:@temporalio/* --external:@grpc/* --outdir=dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mammoth/domain": "workspace:*",
    "@mammoth/governance": "workspace:*",
    "@mammoth/openai-compatible-provider": "workspace:*",
    "@mammoth/observatory-projection": "workspace:*",
    "@mammoth/p7-application-service": "workspace:*",
    "@mammoth/persistence": "workspace:*",
    "@mammoth/provider-port": "workspace:*",
    "@mammoth/report-compiler": "workspace:*",
    "@mammoth/retrieval": "workspace:*",
    "@mammoth/runtime": "workspace:*",
    "@mammoth/temporal-adapter": "workspace:*",
    "@mammoth/workflow": "workspace:*",
    "@temporalio/client": "1.20.2",
    "@temporalio/workflow": "1.20.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
