{
  "name": "@mammoth/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "mammoth": "./dist/bin.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && esbuild src/bin.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/bin.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mammoth/runtime": "workspace:*",
    "@mammoth/temporal-adapter": "workspace:*",
    "@mammoth/workflow": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
